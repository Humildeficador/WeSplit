// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id       String @id @default(nanoid())
  name     String
  email    String @unique
  password String

  groupMembers GroupMember[]
  expenses     Expense[]

  debtsToPay     Debt[] @relation("DebtsToPay")
  debtsToReceive Debt[] @relation("DebtsToReceive")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Group {
  id          String  @id @default(nanoid())
  name        String
  description String?

  members  GroupMember[]
  expenses Expense[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  ADMIN
  MEMBER
}

model GroupMember {
  userId  String
  groupId String
  role    Role   @default(MEMBER)

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  joinedAt DateTime @default(now())

  @@id([userId, groupId])
}

model Expense {
  id String @id @default(nanoid())

  authorId String
  groupId  String

  author User  @relation(fields: [authorId], references: [id])
  group  Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  name        String
  description String?
  value       Int

  debts Debt[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Debt {
  id String @id @default(nanoid())

  debtorId   String
  creditorId String

  expenseId String

  value Int
  paid  Boolean @default(false)

  debtor   User @relation("DebtsToPay", fields: [debtorId], references: [id])
  creditor User @relation("DebtsToReceive", fields: [creditorId], references: [id])

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
